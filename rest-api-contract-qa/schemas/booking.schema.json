{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qa-portfolio.local/schemas/booking.schema.json",
  "title": "Booking",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "booking_id",
    "guest_name",
    "guest_email",
    "room_type",
    "check_in",
    "check_out",
    "total_price",
    "status",
    "created_at"
  ],
  "properties": {
    "booking_id": { "type": "string", "pattern": "^BK-\\d{4}$" },
    "guest_name": { "type": "string", "minLength": 1 },
    "guest_email": { "type": "string", "pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$" },
    "room_type": { "enum": ["standard", "deluxe", "suite"] },
    "check_in": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "check_out": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "total_price": { "type": "number", "exclusiveMinimum": 0 },
    "status": { "enum": ["pending", "confirmed", "cancelled"] },
    "created_at": { "type": "string", "minLength": 19 }
  }
}
